# API runtime
APP_NAME="Hyperlocal Disaster Readiness API"
APP_ENV="local"
APP_VERSION="0.1.0"
API_PREFIX="/api/v1"
LOG_LEVEL="INFO"

# Uncomment and set variable when deploying
# CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# Integrations (placeholders for future integration)
REDIS_URL="redis://localhost:6379/0"
QUEUE_BACKEND="mock"
QUEUE_NAME="image-processing"
QUEUE_DEFAULT_TIMEOUT="300"
QUEUE_RETRY_MAX="3"
# JSON list format for pydantic-settings parsing
QUEUE_RETRY_INTERVALS='[1, 3, 5]'
QUEUE_ENQUEUE_MAX_ATTEMPTS="3"
QUEUE_ENQUEUE_BACKOFF_SECONDS='[0.0, 0.0, 0.0]'
UPLOAD_ALLOWED_CONTENT_TYPES='["image/jpeg", "image/png", "image/webp"]'
UPLOAD_MAX_SIZE_BYTES="10485760" # 10MB
RATE_LIMIT_REPORTS_PER_MINUTE="20"
RATE_LIMIT_REPORT_IMAGES_PER_MINUTE="30"
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SECRET_KEY="YOUR_SUPABASE_SECRET_KEY"
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# --- Database Configuration ---
# DATABASE_URL must be a PostgreSQL connection string, not SUPABASE_URL.
#
# Supabase pooled URL example:
# postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
#
# Shared database URL used by API, routing, and worker.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Use this url if you are running supabase locally
#DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Routing Constraints (Petaling Jaya Bounding Box)
PJ_MIN_LAT="3.03"
PJ_MAX_LAT="3.17"
PJ_MIN_LON="101.55"
PJ_MAX_LON="101.66"
DATA_BACKEND="mock"
ROUTING_BACKEND="mock"
ROUTING_ALGORITHM="dijkstra"
WEATHER_BACKEND="mock"

# Worker runtime
WORKER_API_BASE_URL="http://localhost:8000/api/v1"
WORKER_REDACTED_OUTPUT_DIR="data/processed/redacted"
WORKER_CALLBACK_MAX_ATTEMPTS="3"
WORKER_CALLBACK_TIMEOUT_SECONDS="8"
WORKER_CALLBACK_BACKOFF_SECONDS="1.0"
WORKER_CLASSIFICATION_MODEL_VERSION="efficientnet-b0-best_model.pth"
